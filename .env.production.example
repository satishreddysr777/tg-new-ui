# ── tg-ui · Vercel environment variables ────────────────────────────────────
# Set these in the Vercel project → Settings → Environment Variables.
# Note: API_ORIGIN is baked into the build (next.config rewrites), so changing
# it requires a redeploy.

# Public URL of the Railway API. All /api/v1/* calls are proxied here so the
# session cookie stays first-party to the Vercel domain.
API_ORIGIN=https://YOUR-API.up.railway.app

# MUST be identical to tg-api's JWT_SECRET so the Next middleware can verify the
# session cookie at the edge.
JWT_SECRET=replace-with-the-same-value-as-the-api

# Must match tg-api's SESSION_COOKIE_NAME.
SESSION_COOKIE_NAME=tg_session

# Leave NEXT_PUBLIC_API_URL UNSET so the browser uses the same-origin "/api/v1"
# proxy. Only set it if you ever call the API cross-origin instead of proxying.
